# PrivacyFence configuration example.
# Copy this file to config/settings.yaml and adjust as needed.
#
# This file is USER-level only — privacy policy, which connectors are
# enabled, and auto-accept rules. It carries no secrets:
#
#   - Organization-level app credentials (the Google OAuth client, Slack app,
#     Telegram app, Salesforce Connected App, Atlassian OAuth app) are
#     installed as one bundle via "Install/Update Organization Config…" in
#     the PrivacyFence menu bar. IT admins build that bundle once with
#     scripts/build_org_bundle.py and distribute it.
#   - Per-user sign-in (browser OAuth, or Telegram's phone + code login) is
#     done via "Authenticate…" per connector, also in the menu bar.
#
# Never commit config/settings.yaml or any file under credentials/.

# privacy / drive_privacy / slack_privacy are also editable live from the
# menu bar's "Privacy Filter…" window (no restart needed) -- editing them
# here or from the menu are equivalent.
privacy:
  # Policy applied when a category is not explicitly configured below.
  # One of: allow, redact, block
  default_policy: block

  # Per-category filtering applied BEFORE the user sees the data in the review UI.
  # The privacy filter is a floor (a minimum protection), not a ceiling -
  # the user still has to approve every request.
  #   allow  -> data passes through unchanged
  #   redact -> data is partially masked
  #   block  -> data is replaced with "[BLOCKED BY PRIVACY FILTER]"
  categories:
    body: allow
    metadata: allow        # sender / recipients / date / subject
    attachments: block     # attachment metadata; downloading content is a separate, approval-gated tool
    thread_history: allow

drive_privacy:
  # Also covers Google Sheets (drive_sheets_* tools) - Sheets is not a
  # separate connector, it rides on the Drive connector's OAuth grant.
  default_policy: block
  categories:
    file_content: allow      # the actual document text / bytes (highest risk)
    file_metadata: allow     # name / owners / created/modified times / sharing
    file_list: allow         # results from list operations (names + ids)
    folder_structure: allow  # folder listing results

slack_privacy:
  default_policy: block
  categories:
    message_content: allow   # the text of messages
    user_identity: allow     # user names, emails, real names
    channel_list: allow      # channel names and metadata
    thread_content: allow    # thread reply content

# Enable/disable individual connectors (all enabled by default — this section
# is only needed to turn one off). Toggled automatically when you use
# Disable/Enable in the menu bar. Enabling here isn't enough on its own: a
# connector also needs its organization config installed AND to be
# authenticated (both from the menu bar) before it actually runs.
# connectors:
#   telegram: { enabled: false }

pii_detection:
  # Extra confirmation gate, on top of the normal Allow once/Deny popup:
  # scans the message/document/spreadsheet content shown in the approval
  # popup for likely personal data (Hungarian, English, and German — IBANs,
  # credit card numbers, national ID/tax/social-security numbers, and
  # similar; email addresses and phone numbers are deliberately not
  # detected, see docs/TECHNICAL_REFERENCE.md). When something is flagged,
  # the popup is tinted red and a second "Are you sure?" dialog is required
  # before Allow once (or Always allow) takes effect. Toggled automatically
  # when you use "PII Detection Gate" in the menu bar.
  enabled: true

# Note: unattended_sessions.enabled (privacyfence_begin_unattended_session's
# opt-in gate) is NOT set here. It's a deliberate per-organization choice,
# not a per-user setting, so it lives in the organization config bundle
# (org_config.json, installed via "Install/Update Organization Config…" in
# the menu bar) — see docs/TECHNICAL_REFERENCE.md's "Scheduled / unattended
# Cowork tasks" section.

# Trust a specific resource once — a folder, a task list, a channel, ... —
# instead of adding the same ID to several operation keys under
# auto_accept_rules below. Each entry is grouped by connector and resource
# type, with a small set of capability booleans (read / write / create /
# ...) that decide which operations it actually auto-accepts; every new
# grant starts with every capability off, so adding one does nothing until
# you explicitly flip a capability on. This is also the section the menu
# bar's "Auto-accept Rules → <Connector> → Trusted <Resource>" submenus
# read and write — editing it here or from the menu are equivalent, and
# ``name`` is a cosmetic label (last resolved from the connector, shown in
# the menu) that the evaluator itself never reads. See "Auto-accept grants"
# in docs/TECHNICAL_REFERENCE.md for the full per-connector reference.
# auto_accept_grants:
#   drive:
#     sandbox_folders:
#       # A folder Claude can write into without a popup each time (e.g. a
#       # scratch space you created for it) — also covers Sheets/Docs writes
#       # (write_range/add_sheet/rename_sheet/format_range/insert_dimensions/
#       # delete_dimensions/docs.edit_content/docs.format_content) in that
#       # folder.
#       - id: "<drive folder id>"
#         name: "Claude scratch space"
#         write: true
#     folders:
#       # A folder Claude can read from without a popup (does NOT also grant
#       # write — that's the separate "sandbox_folders" list above).
#       - id: "<drive folder id>"
#         name: "Shared Reports"
#         read: true
#   tasks:
#     task_lists:
#       - id: "<task list id>"
#         name: "Personal"
#         create: true
#         edit: true
#         complete: true
#         move: true

auto_accept_rules:
  contacts.edit:
    # Auto-accept contact edits that don't touch emails/phones (name,
    # organization, or notes-only changes)
    - rule: no_contact_info_change
  # sheets.write_range:
    # Auto-accept writes to spreadsheets created earlier in the same session
    # (e.g. filling in a sheet PrivacyFence just created for you)
    # - rule: created_this_session
  # gmail.create_label:
    # Auto-accept creating labels whose name is in the allowlist (nested
    # names match on the full "Parent/Child" string)
    # - rule: label_name_allowlist
    #   value: ["Receipts", "Travel/Bookings"]
  # Trusting a specific folder, task list, channel, project, space, chat,
  # spreadsheet, calendar, or Salesforce report? Use auto_accept_grants
  # above instead — it's the same underlying mechanism (this is what it
  # compiles down to) but configured once per resource instead of once per
  # operation key.

logging:
  # Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
  level: INFO
  # Log file path. Relative paths are resolved against the project root.
  file: logs/privacyfence.log
