# Loopline configuration example.
# Copy this file to config/settings.yaml and adjust as needed.
# Never commit config/settings.yaml or any file under credentials/.

gmail:
  # OAuth2 client secret downloaded from Google Cloud Console (Desktop app).
  credentials_file: credentials/client_secret.json
  # Where the OAuth token is cached after the first authorization.
  token_file: credentials/token.json

privacy:
  # Policy applied when a category is not explicitly configured below.
  # One of: allow, redact, block
  default_policy: block

  # Per-category filtering applied BEFORE the user sees the data in the review UI.
  # The privacy filter is a floor (a minimum protection), not a ceiling -
  # the user still has to approve every request.
  #   allow  -> data passes through unchanged
  #   redact -> data is partially masked
  #   block  -> data is replaced with "[BLOCKED BY PRIVACY FILTER]"
  categories:
    body: allow
    metadata: allow        # sender / recipients / date / subject
    attachments: block     # attachment metadata (never the content)
    thread_history: allow

drive:
  # OAuth2 client secret downloaded from Google Cloud Console (Desktop app).
  # Shared with Gmail - the same client secret authorizes both services.
  credentials_file: credentials/client_secret.json
  # Where the Drive OAuth token is cached (separate from the Gmail token).
  token_file: credentials/drive_token.json

drive_privacy:
  # Policy applied when a category is not explicitly configured below.
  # One of: allow, redact, block
  default_policy: block

  # Per-category filtering applied BEFORE the user sees the data in the review UI.
  #   allow  -> data passes through unchanged
  #   redact -> data is partially masked
  #   block  -> data is replaced with "[BLOCKED BY PRIVACY FILTER]"
  categories:
    file_content: allow      # the actual document text / bytes (highest risk)
    file_metadata: allow     # name / owners / created/modified times / sharing
    file_list: allow         # results from list operations (names + ids)
    folder_structure: allow  # folder listing results

slack:
  # Bot User OAuth Token (xoxb-...) from your Slack app's "OAuth & Permissions"
  # page. No interactive OAuth flow is needed - this token is used directly.
  # Required scopes: channels:read, groups:read, channels:history,
  # groups:history, users:read, users:read.email, search:read, chat:write.
  bot_token: xoxb-your-token-here

slack_privacy:
  # Policy applied when a category is not explicitly configured below.
  # One of: allow, redact, block
  default_policy: block

  # Per-category filtering applied BEFORE the user sees the data in the review UI.
  #   allow  -> data passes through unchanged
  #   redact -> data is partially masked
  #   block  -> data is replaced with "[BLOCKED BY PRIVACY FILTER]"
  categories:
    message_content: allow   # the text of messages
    user_identity: allow     # user names, emails, real names
    channel_list: allow      # channel names and metadata
    thread_content: allow    # thread reply content

calendar:
  credentials_file: credentials/client_secret.json
  token_file: credentials/calendar_token.json

tasks:
  credentials_file: credentials/client_secret.json
  token_file: credentials/tasks_token.json

salesforce:
  # Salesforce connected app credentials
  # instance_url: https://yourorg.my.salesforce.com
  # username: your@email.com
  # password: yourpassword
  # security_token: yourtoken
  # OR provide:
  # access_token: your_access_token

audit:
  log_dir: logs/audit

auto_accept_rules:
  # Each operation key maps to a list of OR-conditions.
  # The first matching rule triggers auto-accept.
  # Available rule names: see src/loopline/auto_accept.py

  gmail.read_message:
    # Auto-accept reading emails where I am the sender (e.g. sent mail tasks)
    - rule: i_am_sender
    # Auto-accept from trusted internal domain
    # - rule: trusted_sender_domain
    #   value: ["mycompany.com"]
    # Auto-accept if message has specific label
    # - rule: label_match
    #   value: ["AI-readable"]
    # Auto-accept messages older than 30 days
    # - rule: age_threshold_days
    #   value: 30

  gmail.read_thread:
    - rule: i_am_sender

  drive.read_file_contents:
    # Auto-accept files I own
    - rule: i_am_owner
    # Auto-accept files in a specific folder (add folder IDs)
    # - rule: approved_folder
    #   value: []

  drive.write_file:
    # Auto-accept writes to files created this session
    - rule: created_this_session
    # Auto-accept writes inside a designated sandbox folder
    # - rule: approved_sandbox_folder
    #   value: []

  drive.move_file:
    # - rule: move_within_approved_folders
    #   value: []

  drive.comment_file:
    # Comments are lower risk — uncomment to auto-accept all
    # - rule: i_am_owner

  slack.read_messages:
    # Auto-accept reading my own DM (saved messages / Slackbot)
    - rule: dm_with_myself
    # Auto-accept approved channels
    # - rule: approved_channel
    #   value: []

  slack.send_message:
    # Auto-accept sending to myself only
    - rule: dm_with_myself
    # Auto-accept replies in threads I'm already in
    - rule: reply_in_existing_thread
    # - rule: approved_recipient
    #   value: []

  calendar.read_event_details:
    # Auto-accept events I organized
    - rule: i_am_organizer
    # Auto-accept past events
    - rule: past_event
    # Auto-accept internal-only events
    # - rule: no_external_attendees

  calendar.create_modify_event:
    # Auto-accept events with no external attendees
    # - rule: no_external_attendees
    # Auto-accept events on personal calendar (add calendar IDs)
    # - rule: personal_calendar
    #   value: []

  salesforce.read_record:
    # Auto-accept reads on low-sensitivity object types
    # - rule: approved_object_types
    #   value: ["Account", "Contact"]

  salesforce.run_report:
    # Auto-accept specific approved report IDs
    # - rule: approved_report_ids
    #   value: []

mcp:
  server_name: loopline-gmail
  server_version: 0.1.0

drive_mcp:
  server_name: loopline-drive
  server_version: 0.1.0

logging:
  # Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
  level: INFO
  # Log file path. Relative paths are resolved against the project root.
  file: logs/loopline.log
